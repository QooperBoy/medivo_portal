        <mxCell id="ZGODAZAPIS" value="System zapisuje udzieloną zgodę opiekuna (dowód na przyszłość)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="beBox">
          <mxGeometry x="20" y="170" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="RODO" value="System stosuje zasadę RODO: zapisuje tylko niezbędne minimum danych dziecka" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="beBox">
          <mxGeometry x="20" y="290" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ENCJAP" value="System tworzy osobny wpis (encję) podopiecznego w bazie danych" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="beBox">
          <mxGeometry x="20" y="410" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="LINKKONTO" value="System wiąże wpis podopiecznego z kontem rezerwującego — do ponownego użycia" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="beBox">
          <mxGeometry x="20" y="530" width="200" height="60" as="geometry" />
