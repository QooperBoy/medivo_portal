        <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="JA" target="ENCJAJA">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="ENCJAJA" target="DALEJ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="tak — jest już na liście" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="ZAPISANI" target="WYBORZAP">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="nie — pierwsza rezerwacja" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ZAPISANI" target="MINIPROFIL">
