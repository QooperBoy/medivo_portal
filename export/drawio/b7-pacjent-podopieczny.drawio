        <mxCell id="ENCJAJA" value="System zapisuje, że pacjentem jest ta sama osoba co rezerwujący" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="beBox">
