        <mxCell id="e26" value="wysyłka przypomnienia 24 h przed wizytą" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ENG_G2" target="ENG_G1"><mxGeometry relative="1" as="geometry" /></mxCell>
