          <mxGeometry x="655" y="100" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nE13" value="&lt;b&gt;E13&lt;/b&gt;&lt;br&gt;specjalista potwierdza" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="100" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ed1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nSER" target="nG8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
