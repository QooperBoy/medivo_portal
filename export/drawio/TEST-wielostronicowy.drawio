<mxfile host="app.diagrams.net" agent="claude-flows" version="24.0.0">
  <diagram id="spis-tresci" name="00 — Spis treści (TEST)">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;TEST wariantu A — jeden plik draw.io, wiele stron, klikalne przejścia&lt;/b&gt;&lt;br&gt;3 diagramy: E2E-1 → A5 → CORE-STANY" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="730" height="50" as="geometry" />
        </mxCell>
        <UserObject label="🔗 &lt;b&gt;E2E-1&lt;/b&gt;&lt;br&gt;Pacjent nowy&lt;br&gt;(happy path)" link="data:page/id,e2e-1-pacjent-nowy" id="tileE2E">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
            <mxGeometry x="60" y="130" width="220" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="🔗 &lt;b&gt;A5&lt;/b&gt;&lt;br&gt;Checkout rezerwacji&lt;br&gt;(wariant normalny)" link="data:page/id,a5-checkout" id="tileA5">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#2d7dd2;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
            <mxGeometry x="315" y="130" width="220" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="🔗 &lt;b&gt;CORE-STANY&lt;/b&gt;&lt;br&gt;Cykl życia rezerwacji&lt;br&gt;(stany kanoniczne)" link="data:page/id,core-stany-rezerwacji" id="tileCore">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
            <mxGeometry x="570" y="130" width="220" height="90" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="arrow1" value="A5 to węzeł ścieżki E2E-1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="tileE2E" target="tileA5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" value="A5 używa stanów z CORE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="tileA5" target="tileCore">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="panelJak" value="&lt;b&gt;Jak działają klikalne bloki (oznaczone 🔗)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;W edytorze draw.io&lt;/b&gt; (aplikacja / diagrams.net): najedź na blok z 🔗 — pojawi się dymek z linkiem; kliknij go albo użyj &lt;b&gt;Alt+klik&lt;/b&gt; na bloku, żeby przejść na docelową stronę.&lt;br&gt;• &lt;b&gt;W trybie podglądu&lt;/b&gt; (lightbox — np. Extras → Preview albo udostępniony diagram): wystarczy &lt;b&gt;zwykły klik&lt;/b&gt; w blok.&lt;br&gt;• Strony (zakładki na dole okna) to poszczególne diagramy — linki mają postać &quot;data:page/id,…&quot;, więc działają bez internetu i po przeniesieniu pliku.&lt;br&gt;&lt;br&gt;&lt;b&gt;Co jest podlinkowane w tym teście:&lt;/b&gt;&lt;br&gt;• spis → wszystkie 3 diagramy (kafelki powyżej),&lt;br&gt;• E2E-1: blok &quot;A5 checkout&quot; → strona A5,&lt;br&gt;• A5: przycisk &quot;CORE-STANY&quot; oraz strzałka kroku 26 &quot;locked → confirmed&quot; → strona CORE-STANY,&lt;br&gt;• CORE-STANY: stany &quot;draft&quot; i &quot;locked&quot; → strona A5,&lt;br&gt;• każda strona ma przycisk &quot;🏠 Spis&quot; wracający tutaj.&lt;br&gt;&lt;br&gt;W pełnej wersji tak samo podlinkowane będą wszystkie ~60 diagramów (każdy blok z ID innego flow = link do jego strony)." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="730" height="330" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
