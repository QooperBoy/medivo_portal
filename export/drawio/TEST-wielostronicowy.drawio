        </mxCell>
        <mxCell id="e1" value="pacjent klika wybrany termin i wchodzi w checkout (A5)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="start" target="draft">
