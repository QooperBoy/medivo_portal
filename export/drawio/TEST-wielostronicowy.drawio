        <mxCell id="m32" value="32: komunikat „czas na rezerwację minął”" style="html=1;fontSize=10;endArrow=open;endFill=0;dashed=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="440" y="2080" as="sourcePoint" />
            <mxPoint x="280" y="2080" as="targetPoint" />
