          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="pacjent porzuca formularz — rezerwacja znika bez śladu" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="draft" target="endAbandon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="10 minut minęło bez dokończenia — termin wraca do sprzedaży" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="locked" target="endAbandon">
