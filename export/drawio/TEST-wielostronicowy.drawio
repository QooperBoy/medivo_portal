        </mxCell>
        <UserObject label="&lt;b&gt;draft&lt;/b&gt;&lt;br&gt;SZKIC REZERWACJI — pacjent wypełnia formularz,&lt;br&gt;termin NIE jest jeszcze zablokowany&lt;br&gt;(ktoś szybszy wciąż może go zająć)&lt;br&gt;&lt;i&gt;🔗 klik → checkout A5&lt;/i&gt;" link="data:page/id,a5-checkout" id="draft">
