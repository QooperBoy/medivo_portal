        </mxCell>
        <mxCell id="nG8" value="&lt;b&gt;G8&lt;/b&gt;&lt;br&gt;fraud: flaga wzorca" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="245" y="100" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF4" value="&lt;b&gt;F4&lt;/b&gt;&lt;br&gt;przegląd anty-abuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nANU" value="anulowanie serii rezerwacji" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="655" y="100" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nE13" value="&lt;b&gt;E13&lt;/b&gt;&lt;br&gt;specjalista potwierdza" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="100" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ed1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nSER" target="nG8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nG8" target="nF4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nF4" target="nANU">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nANU" target="nE13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="&lt;b&gt;Notatki (1/2)&lt;/b&gt;&lt;br&gt;• Wyjątek od konwencji: bez subgraph FE/BE — węzły to całe flowy (kompozycja ścieżki), nie kroki FE/BE.&lt;br&gt;• &quot;seria rezerwacji&quot; = zdarzenie startowe (podejrzany wzorzec: multikonta, limity per numer/IP/device), nie ID flowu.&lt;br&gt;• G8 (fraud detection, P1) flaguje wzorzec → kolejka F4; w P0 min. wykrycie jest ręczne (zgłoszenie E13 &quot;podejrzewam blokowanie kalendarza&quot; tworzy ticket do F4) — na diagramie ścieżka wg sekwencji z mapy (G8 przed F4).&lt;br&gt;• &quot;anulowanie serii&quot; = akcja admina z F4 (blokady + anulowanie serii), nie osobny flow." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="380" height="190" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;Notatki (2/2)&lt;/b&gt;&lt;br&gt;• E13 na końcu ścieżki: specjalista potwierdza rozwiązanie zgłoszenia; sloty wracają do puli dostępności (E2 → A3/A4).&lt;br&gt;• Diagramy składowe: f4-anty-abuse, e13-zgloszenie-abuse.&lt;br&gt;• Brak pliku diagramu dla: G8 (fraud detection) — odwołanie tylko po ID." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="210" width="380" height="190" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;Legenda:&lt;/b&gt; pomarańczowy = silnik / back office / panel specjalisty · szara elipsa = zdarzenie lub akcja admina (nie flow)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="980" height="30" as="geometry" />
        </mxCell>
        <mxCell id="panel1" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ścieżka obrony przed sabotażem: ktoś (np. nieuczciwa konkurencja) masowo rezerwuje terminy specjalisty, żeby zablokować mu kalendarz. System wykrywania nadużyć flaguje podejrzany wzorzec, admin przegląda sprawę i anuluje serię fikcyjnych rezerwacji, a specjalista potwierdza rozwiązanie zgłoszenia — jego terminy wracają do sprzedaży. Uczestniczą system (automatyczna detekcja), admin (decyzja i anulowanie) oraz specjalista (zgłoszenie/potwierdzenie). Flow zaczyna się od podejrzanej serii rezerwacji, a kończy odblokowaniem kalendarza." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="470" width="880" height="150" as="geometry" />
        </mxCell>
        <mxCell id="panel2" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G8&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;fraud detection flaguje podejrzany wzorzec serii rezerwacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F4&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f4-anty-abuse.md&lt;/td&gt;&lt;td&gt;admin przegląda flagę, blokuje sprawcę i anuluje serię&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E13&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e13-zgloszenie-abuse.md&lt;/td&gt;&lt;td&gt;specjalista zgłasza blokowanie kalendarza i potwierdza rozwiązanie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;odblokowane sloty wracają do grafiku i puli dostępności&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A3&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a3-lista-wynikow.md&lt;/td&gt;&lt;td&gt;uwolnione terminy znów widoczne na liście wyników&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A4&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a4-profil-specjalisty.md&lt;/td&gt;&lt;td&gt;uwolnione terminy znów widoczne na profilu specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="650" width="880" height="270" as="geometry" />
        </mxCell>
        <mxCell id="panel3" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Sabotaż slotów&lt;/td&gt;&lt;td&gt;Celowe blokowanie kalendarza specjalisty fikcyjnymi rezerwacjami.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Multikonto&lt;/td&gt;&lt;td&gt;Wiele kont zakładanych przez tę samą osobę, żeby ominąć limity rezerwacji.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Fraud detection&lt;/td&gt;&lt;td&gt;Automatyczne wykrywanie podejrzanych wzorców rezerwacji (silnik G8).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Flaga&lt;/td&gt;&lt;td&gt;Oznaczenie podejrzanego przypadku, które trafia do przeglądu przez admina.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Limity per numer/IP/device&lt;/td&gt;&lt;td&gt;Ograniczenia liczby rezerwacji z jednego telefonu, adresu sieciowego lub urządzenia.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Anulowanie serii&lt;/td&gt;&lt;td&gt;Hurtowe cofnięcie fikcyjnych rezerwacji przez admina wraz z blokadą sprawcy.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Ticket&lt;/td&gt;&lt;td&gt;Zgłoszenie sprawy do kolejki administratora.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Pula dostępności&lt;/td&gt;&lt;td&gt;Zbiór wolnych terminów widocznych dla pacjentów — anulowane sloty do niej wracają.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;P0 / P1&lt;/td&gt;&lt;td&gt;Priorytety wdrożenia: w wersji minimalnej (P0) wykrywanie jest ręczne, automat G8 dochodzi później (P1).&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="950" width="880" height="350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="e2e-6-dzien-admina" name="E2E-6 — Dzień admina (Back Office)">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1450" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="&lt;b&gt;E2E-6 — Dzień admina (Back Office)&lt;/b&gt;&lt;br&gt;źródło: diagrams/e2e/e2e-6-dzien-admina.md" style="text;html=1;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="110" y="20" width="880" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nF1" value="&lt;b&gt;F1&lt;/b&gt;&lt;br&gt;kolejka weryfikacji PWZ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF2" value="&lt;b&gt;F2&lt;/b&gt;&lt;br&gt;moderacja opinii" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF3" value="&lt;b&gt;F3&lt;/b&gt;&lt;br&gt;spory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF4" value="&lt;b&gt;F4&lt;/b&gt;&lt;br&gt;anty-abuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ed1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nF1" target="nF2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nF2" target="nF3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;" edge="1" parent="1" source="nF3" target="nF4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="&lt;b&gt;Notatki (1/2)&lt;/b&gt;&lt;br&gt;• Wyjątek od konwencji: bez subgraph FE/BE — węzły to całe flowy (kompozycja ścieżki), nie kroki FE/BE.&lt;br&gt;• Ścieżka = kolejność obchodu kolejek Back Office w ciągu dnia (jeden admin, multi-wertykal, filtr per serwis — F9).&lt;br&gt;• Priorytet F1: SLA &quot;do 24 h roboczych&quot; na weryfikację PWZ — dlatego pierwsza w obchodzie." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;Notatki (2/2)&lt;/b&gt;&lt;br&gt;• F3 (spory) formalnie P1; F4 w P0 min. = ręczna blokada.&lt;br&gt;• Każda akcja admina trafia do audit logu F10 (dane zdrowotne!), patrz f10-audit-log.&lt;br&gt;• Diagramy składowe: f1-kolejka-weryfikacji-pwz, f2-moderacja-opinii, f3-spory, f4-anty-abuse." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FFF9B2;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="210" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;Legenda:&lt;/b&gt; pomarańczowy = kolejki Back Office (admin) · strzałki = kolejność obchodu kolejek w ciągu dnia" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="980" height="30" as="geometry" />
        </mxCell>
        <mxCell id="panel1" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Dzień pracy administratora serwisu: kolejność, w jakiej jeden admin obchodzi cztery kolejki Back Office — najpierw weryfikacje numerów PWZ (bo obowiązuje limit czasu na odpowiedź), potem moderację opinii, spory o nieobecności i na końcu przegląd nadużyć. Uczestniczy wyłącznie admin, ale jego decyzje bezpośrednio dotykają specjalistów i pacjentów. Każda wykonana akcja jest trwale zapisywana w dzienniku audytu, ponieważ system przetwarza dane zdrowotne." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="460" width="880" height="150" as="geometry" />
        </mxCell>
        <mxCell id="panel2" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F1&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f1-kolejka-weryfikacji-pwz.md&lt;/td&gt;&lt;td&gt;pierwsza kolejka obchodu — weryfikacja PWZ z SLA do 24 h roboczych&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F2&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f2-moderacja-opinii.md&lt;/td&gt;&lt;td&gt;druga kolejka — moderacja opinii przed publikacją&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F3&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f3-spory.md&lt;/td&gt;&lt;td&gt;trzecia kolejka — rozstrzyganie sporów o no-show&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F4&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f4-anty-abuse.md&lt;/td&gt;&lt;td&gt;czwarta kolejka — przegląd flag i zgłoszeń nadużyć&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F9&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f9-rbac-wertykale.md&lt;/td&gt;&lt;td&gt;filtr per serwis/wertykal określa, które sprawy admin widzi&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F10&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f10-audit-log.md&lt;/td&gt;&lt;td&gt;każda akcja admina jest zapisywana w audit logu&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="640" width="880" height="270" as="geometry" />
        </mxCell>
        <mxCell id="panel3" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Back Office&lt;/td&gt;&lt;td&gt;Wewnętrzny panel administracyjny serwisu, niewidoczny dla pacjentów i specjalistów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Kolejka&lt;/td&gt;&lt;td&gt;Lista spraw czekających na decyzję admina, obsługiwana po kolei.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;PWZ&lt;/td&gt;&lt;td&gt;Numer prawa wykonywania zawodu, weryfikowany przed dopuszczeniem specjalisty do serwisu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SLA&lt;/td&gt;&lt;td&gt;Obiecany maksymalny czas obsługi — dla weryfikacji PWZ do 24 godzin roboczych.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Moderacja&lt;/td&gt;&lt;td&gt;Sprawdzanie treści opinii przed ich publikacją na profilach.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Spór&lt;/td&gt;&lt;td&gt;Sprawa, w której pacjent kwestionuje oznaczenie nieobecności — admin wydaje werdykt.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Anty-abuse&lt;/td&gt;&lt;td&gt;Przegląd zgłoszeń i automatycznych flag dotyczących nadużyć (np. blokowania kalendarza).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wertykal&lt;/td&gt;&lt;td&gt;Odrębna branżowa odsłona serwisu (np. logopedzi) — admin filtruje sprawy per serwis.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;RBAC&lt;/td&gt;&lt;td&gt;System ról i uprawnień decydujący, co dany admin widzi i jakie akcje może wykonać.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Audit log&lt;/td&gt;&lt;td&gt;Trwały zapis każdej akcji admina, wymagany przy przetwarzaniu danych zdrowotnych.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="110" y="940" width="880" height="380" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
