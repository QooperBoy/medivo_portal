        <mxCell id="m20" value="20: powiadomienie do następnego pacjenta" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1010" y="1435" as="sourcePoint" />
            <mxPoint x="1590" y="1435" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="note3" value="pętla aż do wyczerpania kolejki" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#d6b656;fontSize=11;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1110" y="1470" width="380" height="30" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram opisuje działanie waitlisty, czyli listy oczekujących na termin. Pacjent, dla którego zabrakło wolnych slotów, zapisuje się na powiadomienie; gdy jakiś termin się zwolni (np. ktoś odwoła wizytę), system powiadamia pierwszą osobę z kolejki i daje jej 2 godziny na potwierdzenie. Potwierdzenie od razu tworzy rezerwację i powiadamia specjalistę o nowej wizycie; brak reakcji przekazuje termin kolejnej osobie z listy." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1620" width="1680" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;ID&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Plik&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G6&lt;/td&gt;&lt;td&gt;diagrams/g-silniki/g6-waitlist-engine.md&lt;/td&gt;&lt;td&gt;silnik FIFO obsługujący kolejkę i okno 2 h&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A8&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a8-brak-slotow.md&lt;/td&gt;&lt;td&gt;wejście: zapis na waitlistę przy braku terminów&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B3&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b3-odwolanie-tokenem.md&lt;/td&gt;&lt;td&gt;odwołanie pacjenta zwalnia slot dla waitlisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E5&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e5-odwolanie-pojedyncze.md&lt;/td&gt;&lt;td&gt;odwołanie przez specjalistę też zwalnia slot&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E6&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e6-tryb-urlop.md&lt;/td&gt;&lt;td&gt;zbiorcze odwołania (urlop) jako źródło zwolnionych slotów&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G1&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;notification engine wysyła potwierdzenia po auto-booku&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A7&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a7-potwierdzenie.md&lt;/td&gt;&lt;td&gt;potwierdzenia rezerwacji po auto-booku jak po checkoucie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A5&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a5-checkout.md&lt;/td&gt;&lt;td&gt;auto-book pomija pełny checkout (założenie)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A3&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a3-lista-wynikow.md&lt;/td&gt;&lt;td&gt;po wyczerpaniu kolejki slot wraca do publicznej dostępności&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A4&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a4-profil-specjalisty.md&lt;/td&gt;&lt;td&gt;zwolniony slot znów widoczny na profilu specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CORE-STANY&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-stany-rezerwacji.md&lt;/td&gt;&lt;td&gt;auto-book prowadzi wprost do stanu confirmed&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2E-2&lt;/td&gt;&lt;td&gt;diagrams/e2e/e2e-2-zmiana-terminu.md&lt;/td&gt;&lt;td&gt;waitlista jest ogniwem ścieżki „Pacjent zmienia termin”&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1770" width="1680" height="440" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;Pojęcie&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Waitlista&lt;/td&gt;&lt;td&gt;Lista pacjentów czekających na zwolnienie się terminu u danego specjalisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FIFO&lt;/td&gt;&lt;td&gt;Kolejność „kto pierwszy się zapisał, ten pierwszy dostaje propozycję” (first in, first out).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Slot&lt;/td&gt;&lt;td&gt;Pojedynczy wolny termin wizyty w grafiku specjalisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Okno 2 h&lt;/td&gt;&lt;td&gt;Czas, jaki powiadomiony pacjent ma na potwierdzenie zwolnionego terminu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Auto-book&lt;/td&gt;&lt;td&gt;Automatyczne utworzenie rezerwacji po kliknięciu „potwierdź termin”, bez przechodzenia pełnego checkoutu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Kaskada&lt;/td&gt;&lt;td&gt;Przekazywanie propozycji terminu kolejnym osobom z kolejki, aż ktoś potwierdzi lub lista się wyczerpie.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Timeout&lt;/td&gt;&lt;td&gt;Upłynięcie czasu na reakcję — po 2 h bez potwierdzenia propozycja przepada.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Event&lt;/td&gt;&lt;td&gt;Wewnętrzny komunikat systemu (np. „slot zwolniony”), który uruchamia automatyczne kroki.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;confirmed&lt;/td&gt;&lt;td&gt;Stan rezerwacji „potwierdzona” — wizyta umówiona.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="2240" width="1680" height="360" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
