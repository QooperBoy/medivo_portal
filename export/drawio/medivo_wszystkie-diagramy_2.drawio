        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram pokazuje zarządzanie treściami serwisu (landingi, strony miast i usług), które przyciągają pacjentów z wyszukiwarek. Na starcie (etap P0) treści są zapisane na sztywno w kodzie i zmienia się je przez wgranie nowej wersji serwisu; docelowo (etap P1) admin edytuje je w interfejsie CMS-a, osobno dla każdego forka, czyli wertykalu. Publikacja odświeża strony widoczne dla pacjentów i uruchamia automatyczne zadania SEO: aktualizację sitemapy i danych schema.org." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="920" height="140" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A1&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a1-wejscie-seo.md&lt;/td&gt;&lt;td&gt;opublikowane treści zasilają strony, na które pacjent wchodzi z wyszukiwarki&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A9&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a9-strony-statyczne.md&lt;/td&gt;&lt;td&gt;strony statyczne pochodzą z CMS-a lub hardcode'u&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G12&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;publikacja uruchamia joby SEO: sitemap i schema.org refresh&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F8&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f8-konfiguracja-forka.md&lt;/td&gt;&lt;td&gt;treści są prowadzone per fork zdefiniowany w konfiguracji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F10&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f10-audit-log.md&lt;/td&gt;&lt;td&gt;zmiany treści (w etapie P1) zapisywane w audycie&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1030" width="920" height="240" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CMS&lt;/td&gt;&lt;td&gt;System do edycji treści stron przez admina bez zmieniania kodu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SEO&lt;/td&gt;&lt;td&gt;Działania zwiększające widoczność serwisu w wynikach wyszukiwarek.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Fork&lt;/td&gt;&lt;td&gt;Osobna kopia serwisu dla innej branży, korzystająca ze wspólnego rdzenia.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Wertykal&lt;/td&gt;&lt;td&gt;Branża/specjalizacja obsługiwana przez dany fork (np. logopedzi).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Hardcode&lt;/td&gt;&lt;td&gt;Treści wpisane na stałe w kod serwisu — zmiana wymaga programisty i deployu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Deploy&lt;/td&gt;&lt;td&gt;Wgranie nowej wersji serwisu na serwery.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SSR/SSG&lt;/td&gt;&lt;td&gt;Sposób budowania stron na serwerze, dzięki któremu wyszukiwarki dobrze je indeksują.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Sitemap&lt;/td&gt;&lt;td&gt;Mapa wszystkich stron serwisu przekazywana wyszukiwarkom.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Schema.org&lt;/td&gt;&lt;td&gt;Ustandaryzowane znaczniki w treści strony, które pomagają wyszukiwarce zrozumieć, co na niej jest.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1300" width="920" height="350" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
