        <mxCell id="m16" value="16: pacjent zamyka lub opuszcza&lt;br&gt;stronę checkoutu" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
