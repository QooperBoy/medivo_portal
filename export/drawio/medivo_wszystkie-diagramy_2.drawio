        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram pokazuje publikację profilu specjalisty (go-live) — jedno kliknięcie dostępne po pomyślnej weryfikacji PWZ (D1). System najpierw sprawdza, czy specjalista faktycznie ma status „zweryfikowany&quot;; jeśli nie, przycisk pozostaje nieaktywny. Po publikacji szkic profilu z D2 staje się publiczny: specjalista pojawia się w wynikach wyszukiwania (A3) i na stronie profilu (A4), aktualizuje się mapa strony dla wyszukiwarek, a specjalista dostaje mail powitalny. Flow kończy się publicznie widocznym profilem i wskazaniem następnych kroków (grafik, usługi, rezerwacje)." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="1020" height="160" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d1-weryfikacja-pwz.md&lt;/td&gt;&lt;td&gt;pozytywny wynik weryfikacji jest warunkiem go-live&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d2-stan-w-trakcie.md&lt;/td&gt;&lt;td&gt;publikowany jest draft profilu przygotowany podczas weryfikacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A3&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a3-lista-wynikow.md&lt;/td&gt;&lt;td&gt;po publikacji specjalista pojawia się w wynikach wyszukiwania&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A4&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a4-profil-specjalisty.md&lt;/td&gt;&lt;td&gt;po publikacji profil staje się publiczną stroną specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;następny krok po go-live — bez grafiku nie pojawią się sloty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E3&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e3-uslugi-ceny.md&lt;/td&gt;&lt;td&gt;następny krok po go-live — bez usług i cen nie pojawią się sloty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E4&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e4-rezerwacje.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki E2E — obsługa pierwszych rezerwacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G1&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;mail powitalny wysyła notification engine (G1)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G12&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;aktualizację sitemap wykonuje job SEO (G12)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CORE-WERYFIKACJA&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-weryfikacja-specjalisty.md&lt;/td&gt;&lt;td&gt;guard „stan: zweryfikowany?&quot; opiera się na kanonicznym cyklu weryfikacji&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="930" width="1020" height="430" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Go-live&lt;/td&gt;&lt;td&gt;Moment, w którym profil specjalisty staje się publicznie widoczny.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Publikacja profilu&lt;/td&gt;&lt;td&gt;Zamiana roboczego szkicu (draftu) na profil widoczny dla pacjentów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Draft profilu&lt;/td&gt;&lt;td&gt;Niepubliczny szkic profilu przygotowany podczas weryfikacji (D2).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Guard&lt;/td&gt;&lt;td&gt;Warunek blokujący po stronie systemu — publikacja wykona się tylko dla specjalisty zweryfikowanego.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Obrona w głąb&lt;/td&gt;&lt;td&gt;Zasada, że blokada działa i w przycisku (FE), i w systemie (BE), na wypadek obejścia jednej z nich.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Sitemap&lt;/td&gt;&lt;td&gt;Mapa strony dla wyszukiwarek (np. Google) — jej aktualizacja pomaga szybciej znaleźć nowy profil.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;SEO&lt;/td&gt;&lt;td&gt;Działania zwiększające widoczność serwisu w wyszukiwarkach; sitemap aktualizuje job G12.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Mail powitalny&lt;/td&gt;&lt;td&gt;Automatyczna wiadomość e-mail wysyłana specjaliście po publikacji profilu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Notification engine&lt;/td&gt;&lt;td&gt;Silnik powiadomień (G1) rozsyłający w serwisie maile i SMS-y.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Slot&lt;/td&gt;&lt;td&gt;Konkretny termin wizyty w kalendarzu — pojawi się publicznie, gdy grafik i usługi są uzupełnione.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1390" width="1020" height="430" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
