        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ekran panelu, na którym specjalista zarządza swoją ofertą: dodaje usługi z gotowego słownika (nie wymyśla własnych nazw), ustawia dla nich cenę, czas trwania i tryb (online lub stacjonarnie), edytuje je i usuwa. Zmiany zapisuje system, a ich efekty widać w dwóch miejscach: na publicznym profilu specjalisty (cennik dla pacjentów) oraz w grafiku, gdzie czas trwania usługi wyznacza długość slotu." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="750" width="980" height="140" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A4&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a4-profil-specjalisty.md&lt;/td&gt;&lt;td&gt;usługi i ceny są widoczne na publicznym profilu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A5&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a5-checkout.md&lt;/td&gt;&lt;td&gt;wybór usługi to krok checkoutu rezerwacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;czas trwania usługi determinuje długość slotu w grafiku&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E5&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e5-odwolanie-pojedyncze.md&lt;/td&gt;&lt;td&gt;nierozstrzygnięte: czy usunięcie usługi z przyszłymi rezerwacjami wymusza odwołania&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F8&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f8-konfiguracja-forka.md&lt;/td&gt;&lt;td&gt;słownik usług wertykalu pochodzi z konfiguracji forka&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="920" width="980" height="250" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;słownik usług&lt;/td&gt;&lt;td&gt;zamknięta, ustalona przez administrację lista nazw usług, z której specjalista wybiera swoją ofertę&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;wertykal&lt;/td&gt;&lt;td&gt;branża/specjalizacja, dla której działa dana wersja serwisu (tu: logopedzi)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;fork&lt;/td&gt;&lt;td&gt;osobna instancja serwisu dla innego wertykalu, z własną konfiguracją (m.in. słownikiem usług)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CRUD&lt;/td&gt;&lt;td&gt;podstawowe operacje na danych: dodawanie, odczyt, edycja i usuwanie (tu: usług)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;tryb online / stacjonarnie&lt;/td&gt;&lt;td&gt;określenie, czy usługa odbywa się zdalnie, czy w gabinecie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;slot&lt;/td&gt;&lt;td&gt;pojedynczy termin wizyty w grafiku; jego długość wynika z czasu trwania usługi&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;checkout&lt;/td&gt;&lt;td&gt;proces rezerwacji wizyty przez pacjenta, w którym wybiera on m.in. usługę&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1200" width="980" height="300" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
