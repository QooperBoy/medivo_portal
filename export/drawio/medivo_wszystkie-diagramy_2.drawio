        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ekran subskrypcji w panelu specjalisty: aktualny plan (na start darmowy), licznik &quot;free do DD.MM&quot; odliczany od dnia rejestracji, metoda płatności i faktury do pobrania. W tle billing engine nalicza abonament i wystawia faktury VAT, a gdy okres darmowy się kończy, specjalista widzi zachętę do wyboru płatnego planu. Dotyczy rozliczeń specjalisty z serwisem (B2B) — nie płatności pacjentów za wizyty." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="1000" height="140" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c2-cennik-b2b.md&lt;/td&gt;&lt;td&gt;plany free/płatne pochodzą z cennika B2B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C3&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c3-rejestracja.md&lt;/td&gt;&lt;td&gt;okres free startuje w dniu rejestracji specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E1&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e1-dashboard.md&lt;/td&gt;&lt;td&gt;alert o statusie subskrypcji widoczny na dashboardzie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E11&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e11-ustawienia.md&lt;/td&gt;&lt;td&gt;dane do faktur pochodzą z ustawień specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F6&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f6-billing-admin.md&lt;/td&gt;&lt;td&gt;administracyjna strona billingu: subskrypcje, windykacja&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="1000" height="240" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;subskrypcja&lt;/td&gt;&lt;td&gt;abonament specjalisty za korzystanie z serwisu, rozliczany cyklicznie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;plan free&lt;/td&gt;&lt;td&gt;darmowy plan startowy, obowiązujący od dnia rejestracji przez określony czas&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;licznik free&lt;/td&gt;&lt;td&gt;widoczna od pierwszego dnia informacja &quot;free do DD.MM&quot; — do kiedy trwa okres darmowy&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;billing engine&lt;/td&gt;&lt;td&gt;mechanizm systemu naliczający opłaty abonamentowe i pilnujący terminów&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;faktura VAT&lt;/td&gt;&lt;td&gt;dokument księgowy wystawiany specjaliście za abonament, do pobrania z panelu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;metoda płatności&lt;/td&gt;&lt;td&gt;zapisany sposób opłacania abonamentu (np. karta)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B2B&lt;/td&gt;&lt;td&gt;rozliczenie firma-firma: specjalista płaci serwisowi, niezależnie od płatności pacjentów&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;grace period&lt;/td&gt;&lt;td&gt;ewentualny okres łaski po końcu free, zanim system coś zablokuje — nierozstrzygnięte w mapie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;windykacja&lt;/td&gt;&lt;td&gt;dochodzenie zaległych płatności — obsługiwane po stronie admina (F6)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
