        <mxCell id="p1" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Krok po kroku pokazuje, co się dzieje, gdy specjalista odwołuje lub przesuwa jedną wizytę pacjenta. Specjalista wybiera wizytę i powód z gotowego szablonu, widzi podgląd „ludzkiego&quot; komunikatu, a po potwierdzeniu system zmienia stan wizyty, zwalnia slot na waitlistę i wysyła pacjentowi SMS/email — przy odwołaniu z propozycjami innych terminów lub podobnych specjalistów, przy przesunięciu z nowym terminem i linkiem do samodzielnego zarządzania wizytą. Specjalista może też zrezygnować z akcji i wtedy nic się nie zmienia." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1700" width="1610" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;ID&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Plik&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E4&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e4-rezerwacje.md&lt;/td&gt;&lt;td&gt;wejście do flow — specjalista wybiera wizytę z listy rezerwacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;nowy slot przy przesunięciu i auto-propozycje pochodzą z grafiku&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B3&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b3-odwolanie-tokenem.md&lt;/td&gt;&lt;td&gt;pacjent po przesunięciu może odwołać wizytę linkiem z tokenem&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B4&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b4-waitlista.md&lt;/td&gt;&lt;td&gt;zwolniony slot jest proponowany oczekującym z waitlisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A5&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a5-checkout.md&lt;/td&gt;&lt;td&gt;pacjent korzystający z propozycji przechodzi nowy checkout&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A8&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a8-brak-slotow.md&lt;/td&gt;&lt;td&gt;wzorzec propozycji „podobni specjaliści&quot; pochodzi z tego flow&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G1&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-katalog-eventow.md&lt;/td&gt;&lt;td&gt;powiadomienia SMS/email wysyła notification engine (G1)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;G6&lt;/td&gt;&lt;td&gt;diagrams/g-silniki/g6-waitlist-engine.md&lt;/td&gt;&lt;td&gt;silnik waitlisty przejmuje zwolniony slot&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CORE-STANY&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-stany-rezerwacji.md&lt;/td&gt;&lt;td&gt;przejście confirmed → cancelled_by_specialist wg kanonu stanów&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="1880" width="1610" height="400" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;Pojęcie&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;odwołanie&lt;/td&gt;&lt;td&gt;anulowanie wizyty przez specjalistę — wizyta nie odbędzie się&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;przesunięcie&lt;/td&gt;&lt;td&gt;zmiana terminu wizyty na inny slot bez jej anulowania (stan pozostaje confirmed)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;szablon powodu&lt;/td&gt;&lt;td&gt;gotowa lista przyczyn odwołania, z której generowany jest zrozumiały komunikat dla pacjenta&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;auto-propozycje&lt;/td&gt;&lt;td&gt;automatycznie dobrane alternatywy dla pacjenta: inne terminy tego specjalisty lub podobni specjaliści&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;licznik odwołań&lt;/td&gt;&lt;td&gt;licznik zliczający, ile wizyt specjalista odwołał (rośnie przy odwołaniu, nie przy przesunięciu)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;waitlista&lt;/td&gt;&lt;td&gt;lista pacjentów czekających na zwolniony termin&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;slot&lt;/td&gt;&lt;td&gt;pojedynczy termin wizyty w grafiku specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;event booking.cancelled&lt;/td&gt;&lt;td&gt;wewnętrzny sygnał systemu „wizyta odwołana&quot;, uruchamiający powiadomienia i waitlistę&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;token zarządzania&lt;/td&gt;&lt;td&gt;link w SMS/emailu pozwalający pacjentowi zmienić lub odwołać wizytę bez logowania&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="2310" width="1610" height="380" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
