        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram opisuje ekran „Moje wizyty” zalogowanego pacjenta. System pobiera listę rezerwacji i dzieli je na nadchodzące oraz historię, pokazując przy każdej wizycie jej status. Flow zaczyna się po zalogowaniu, a kończy przejściem do szczegółów wizyty i dostępnych akcji: zarządzania wizytą (zmiana/odwołanie) lub wystawienia opinii. Uczestniczą pacjent i system." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="960" height="130" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;ID&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Plik&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B1&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b1-logowanie.md&lt;/td&gt;&lt;td&gt;wejście — ekran dostępny po zalogowaniu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B3&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b3-odwolanie-tokenem.md&lt;/td&gt;&lt;td&gt;akcja „zarządzaj” przy wizycie prowadzi do zmiany/odwołania&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B5&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b5-wystawienie-opinii.md&lt;/td&gt;&lt;td&gt;skrót z historii wizyt do formularza opinii&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B4&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b4-waitlista.md&lt;/td&gt;&lt;td&gt;otwarta kwestia, czy wpisy waitlisty są tu widoczne&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CORE-STANY&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-stany-rezerwacji.md&lt;/td&gt;&lt;td&gt;statusy na listach = kanoniczne stany rezerwacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A3&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a3-lista-wynikow.md&lt;/td&gt;&lt;td&gt;wzorzec pustego stanu przyjęty z listy wyników&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1010" width="960" height="280" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th align=&quot;left&quot;&gt;Pojęcie&lt;/th&gt;&lt;th align=&quot;left&quot;&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Status kanoniczny&lt;/td&gt;&lt;td&gt;Jedna z ustalonych dla całego systemu nazw stanu rezerwacji, używana wszędzie tak samo.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;confirmed&lt;/td&gt;&lt;td&gt;Wizyta potwierdzona — termin jest umówiony i aktualny.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;pending_payment&lt;/td&gt;&lt;td&gt;Rezerwacja czeka na opłacenie przez pacjenta.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;pending_approval&lt;/td&gt;&lt;td&gt;Rezerwacja czeka na akceptację przez specjalistę.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;no_show&lt;/td&gt;&lt;td&gt;Pacjent nie stawił się na wizycie.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;disputed&lt;/td&gt;&lt;td&gt;Wizyta jest przedmiotem sporu (pacjent zakwestionował oznaczenie no-show).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Pusty stan&lt;/td&gt;&lt;td&gt;Ekran pokazywany, gdy lista nie ma żadnych pozycji (brak wizyt).&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1320" width="960" height="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
