        <mxCell id="nE4" value="&lt;b&gt;E4&lt;/b&gt;&lt;br&gt;pierwsza rezerwacja" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
