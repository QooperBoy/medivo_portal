        <mxCell id="e13" value="podgląd wolnych slotów na żywo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="AVAIL" target="GRAFIK">
