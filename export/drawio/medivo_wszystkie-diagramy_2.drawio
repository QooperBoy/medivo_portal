        <mxCell id="m18" value="18: upływ limitu 24 h na akceptację" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
