        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ekran startowy panelu specjalisty (np. logopedy) — pierwsza rzecz, jaką widzi po zalogowaniu. System zbiera w jednym miejscu dzisiejsze wizyty, nowe rezerwacje (w tym prośby wymagające ręcznej akceptacji) oraz alerty: o sporach z pacjentami, o nowych opiniach czekających na odpowiedź i o statusie abonamentu. Dashboard sam niczego nie zmienia — to punkt wyjścia, z którego specjalista przechodzi do szczegółowych ekranów, przede wszystkim do listy rezerwacji." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="780" width="1000" height="140" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E4&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e4-rezerwacje.md&lt;/td&gt;&lt;td&gt;dzisiejsze wizyty i nowe rezerwacje (w tym prośby o akceptację) prowadzą do tego ekranu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E8&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e8-approval-opinie.md&lt;/td&gt;&lt;td&gt;alert o nowych opiniach do odpowiedzi kieruje do pipeline&amp;#39;u opinii&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E12&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e12-subskrypcja-billing.md&lt;/td&gt;&lt;td&gt;alert o statusie subskrypcji i liczniku okresu free&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B6&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b6-spor-no-show.md&lt;/td&gt;&lt;td&gt;spory zgłaszane przez pacjentów są źródłem alertu o sporach&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F2&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f2-moderacja-opinii.md&lt;/td&gt;&lt;td&gt;moderacja opinii zasila agregacje danych o opiniach&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F3&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f3-spory.md&lt;/td&gt;&lt;td&gt;kolejka sporów po stronie admina — drugie źródło alertu o sporach&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="950" width="1000" height="260" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;dashboard&lt;/td&gt;&lt;td&gt;ekran startowy panelu pokazujący najważniejsze informacje w jednym miejscu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;agregacja&lt;/td&gt;&lt;td&gt;zebranie danych z kilku źródeł (rezerwacje, opinie, spory, billing) w jedno podsumowanie&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;alert&lt;/td&gt;&lt;td&gt;wyróżnione powiadomienie na dashboardzie o sprawie wymagającej uwagi specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;prośba o akceptację&lt;/td&gt;&lt;td&gt;rezerwacja, którą specjalista musi ręcznie zatwierdzić, zanim zostanie potwierdzona (stan pending_approval)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;subskrypcja&lt;/td&gt;&lt;td&gt;abonament specjalisty za korzystanie z serwisu (na start darmowy okres free)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;spór&lt;/td&gt;&lt;td&gt;sytuacja, w której pacjent kwestionuje oznaczenie wizyty jako &quot;nie stawił się&quot;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;opinia&lt;/td&gt;&lt;td&gt;ocena i komentarz pacjenta po odbytej wizycie, na które specjalista może odpowiedzieć&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;billing engine&lt;/td&gt;&lt;td&gt;mechanizm systemu naliczający opłaty abonamentowe i pilnujący statusu subskrypcji&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1240" width="1000" height="320" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
