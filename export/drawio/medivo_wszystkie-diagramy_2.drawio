        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Zbiór stałych stron informacyjnych serwisu: cennik, zasady działania wyników wyszukiwania, regulamin, polityka prywatności i pomoc. Pacjent trafia na nie z nawigacji lub stopki i po prostu czyta treść — flow nie kończy się żadną transakcją. Na start treści są wpisane na sztywno w kod, a docelowo będzie nimi zarządzał admin przez CMS (F7)." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="1020" height="120" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Diagram&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A2&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a2-wyszukiwanie.md&lt;/td&gt;&lt;td&gt;strona /jak-dzialaja-wyniki jest linkowana z wyszukiwania (wymóg Omnibus)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;A5&lt;/td&gt;&lt;td&gt;diagrams/a-pacjent-public/a5-checkout.md&lt;/td&gt;&lt;td&gt;/regulamin i /prywatnosc to podstawa prawna zgód z checkoutu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B3&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b3-odwolanie-tokenem.md&lt;/td&gt;&lt;td&gt;/pomoc opisuje, jak odwołać lub zmienić wizytę&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B4&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b4-waitlista.md&lt;/td&gt;&lt;td&gt;/pomoc opisuje zasady działania waitlisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B9&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b9-rodo-self-service.md&lt;/td&gt;&lt;td&gt;/prywatnosc wiąże się z samoobsługą praw RODO&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c2-cennik-b2b.md&lt;/td&gt;&lt;td&gt;cennik B2B dla specjalistów to osobny flow, odrębny od /cennik&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F7&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f7-cms-seo.md&lt;/td&gt;&lt;td&gt;docelowe źródło treści — CMS zarządzany przez admina&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="1020" height="280" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Strona statyczna&lt;/td&gt;&lt;td&gt;Strona o stałej, informacyjnej treści, bez interakcji (np. regulamin).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Hardcode&lt;/td&gt;&lt;td&gt;Treść wpisana na sztywno w kod aplikacji — najszybsze rozwiązanie na start.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CMS&lt;/td&gt;&lt;td&gt;System zarządzania treścią, dzięki któremu admin edytuje strony bez udziału programisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Render&lt;/td&gt;&lt;td&gt;Wygenerowanie i wyświetlenie treści strony użytkownikowi.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Omnibus&lt;/td&gt;&lt;td&gt;Dyrektywa UE wymagająca m.in. jawnego opisania zasad układania wyników — stąd strona /jak-dzialaja-wyniki.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;RODO&lt;/td&gt;&lt;td&gt;Przepisy o ochronie danych osobowych — podstawa strony /prywatnosc.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B2B&lt;/td&gt;&lt;td&gt;Oferta dla specjalistów/firm (płatny abonament), odrębna od bezpłatnego serwisu dla pacjentów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;P0 / P1&lt;/td&gt;&lt;td&gt;Priorytety wdrożenia: P0 = niezbędne na start, P1 = zaraz po starcie.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="1020" height="310" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
