          </mxGeometry>
        </mxCell>
        <mxCell id="n2" value="strona nie wysyła sygnału o porzuceniu — blokada czeka do końca 10 minut (założenie)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=#d6b656;fontSize=11;align=left;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="675" y="1545" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m17" value="17: timer zgłasza, że 10 minut (TTL)&lt;br&gt;upłynęło" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
