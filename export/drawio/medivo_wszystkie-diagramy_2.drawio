        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram pokazuje stronę z cennikiem dla specjalistów (oferta B2B). Specjalista trafia tu zwykle z landingu C1, ogląda jedyny dostępny na start plan Free oraz zapowiedź planów płatnych („wkrótce&quot;), po czym albo zakłada konto, albo wraca na landing. To strona czysto informacyjna — system nie wykonuje w tle żadnych operacji. Flow kończy się przejściem do rejestracji (C3) lub powrotem do C1." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="1020" height="150" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c1-landing-dla-specjalistow.md&lt;/td&gt;&lt;td&gt;wejście na cennik z landingu i możliwy powrót na landing&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C3&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c3-rejestracja.md&lt;/td&gt;&lt;td&gt;CTA cennika prowadzi do rejestracji specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d1-weryfikacja-pwz.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki specjalisty — weryfikacja PWZ po rejestracji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d2-stan-w-trakcie.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki — onboarding w trakcie weryfikacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D3&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d3-go-live.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki — publikacja profilu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki po go-live — ustawienie grafiku&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E3&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e3-uslugi-ceny.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki po go-live — usługi i ceny&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E12&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e12-subskrypcja-billing.md&lt;/td&gt;&lt;td&gt;plan z cennika widoczny później w panelu jako subskrypcja (licznik „free do DD.MM&quot;)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F6&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f6-billing-admin.md&lt;/td&gt;&lt;td&gt;ten sam model subskrypcji rozliczany po stronie admina&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="970" width="1020" height="400" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B2B&lt;/td&gt;&lt;td&gt;Oferta dla specjalistów/firm (klient biznesowy), w odróżnieniu od części serwisu dla pacjentów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Cennik&lt;/td&gt;&lt;td&gt;Strona prezentująca dostępne plany abonamentowe i ich zakres.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Plan Free&lt;/td&gt;&lt;td&gt;Darmowy plan abonamentowy — jedyny dostępny na starcie serwisu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Plany płatne&lt;/td&gt;&lt;td&gt;Przyszłe, płatne warianty abonamentu; na razie tylko zapowiedź „wkrótce&quot;, bez szczegółów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Subskrypcja&lt;/td&gt;&lt;td&gt;Cykliczna opłata za korzystanie z serwisu przez specjalistę.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CTA&lt;/td&gt;&lt;td&gt;Przycisk wzywający do działania (call to action), tutaj „załóż konto&quot;.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Strona statyczna&lt;/td&gt;&lt;td&gt;Strona o stałej treści, bez pobierania danych z systemu (brak API).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Billing&lt;/td&gt;&lt;td&gt;Rozliczenia i płatności za subskrypcję — widoczne dla specjalisty w E12, a dla admina w F6.&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1400" width="1020" height="380" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
