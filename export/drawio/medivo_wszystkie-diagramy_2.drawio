        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ten diagram pokazuje stronę marketingową /dla-specjalistow — pierwszy kontakt logopedy (specjalisty) z serwisem. Specjalista trafia na nią np. z wyszukiwarki lub reklamy, przegląda ofertę („0 zł przez 6 mies.&quot;), opinie innych i FAQ, a następnie decyduje, co dalej: zakłada konto, przechodzi do cennika albo opuszcza stronę. Po stronie systemu nic się nie dzieje — to zwykła strona statyczna bez logiki. Flow kończy się przejściem do rejestracji (C3), do cennika (C2) lub wyjściem ze strony." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1020" width="1020" height="150" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c2-cennik-b2b.md&lt;/td&gt;&lt;td&gt;landing linkuje do szczegółów cennika B2B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C3&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c3-rejestracja.md&lt;/td&gt;&lt;td&gt;główne CTA landingu prowadzi do rejestracji specjalisty&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d1-weryfikacja-pwz.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki specjalisty — weryfikacja PWZ po rejestracji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d2-stan-w-trakcie.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki — onboarding w trakcie weryfikacji&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D3&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d3-go-live.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki — publikacja profilu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E2&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e2-grafik-dostepnosc.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki po go-live — ustawienie grafiku&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E3&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e3-uslugi-ceny.md&lt;/td&gt;&lt;td&gt;dalszy ciąg ścieżki po go-live — usługi i ceny&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;E12&lt;/td&gt;&lt;td&gt;diagrams/e-panel/e12-subskrypcja-billing.md&lt;/td&gt;&lt;td&gt;oferta z landingu odpowiada modelowi subskrypcji widocznemu w panelu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F6&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f6-billing-admin.md&lt;/td&gt;&lt;td&gt;ten sam model subskrypcji rozliczany po stronie admina&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F7&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f7-cms-seo.md&lt;/td&gt;&lt;td&gt;docelowo (P1) treść landingu zarządzana przez CMS&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1200" width="1020" height="430" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Landing&lt;/td&gt;&lt;td&gt;Strona docelowa, na którą trafia specjalista z reklamy lub wyszukiwarki, mająca zachęcić go do założenia konta.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Value prop&lt;/td&gt;&lt;td&gt;Propozycja wartości — krótkie wyjaśnienie, co specjalista zyskuje dzięki serwisowi.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Social proof&lt;/td&gt;&lt;td&gt;Opinie i przykłady innych użytkowników, które budują zaufanie do serwisu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CTA&lt;/td&gt;&lt;td&gt;Przycisk wzywający do działania (call to action), tutaj „załóż konto&quot;.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B2B&lt;/td&gt;&lt;td&gt;Oferta skierowana do specjalistów/firm (klient biznesowy), a nie do pacjentów.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;FAQ&lt;/td&gt;&lt;td&gt;Sekcja najczęściej zadawanych pytań wraz z odpowiedziami.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Strona statyczna&lt;/td&gt;&lt;td&gt;Strona o stałej treści, która nie pobiera danych z systemu (brak API).&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CMS&lt;/td&gt;&lt;td&gt;System zarządzania treścią — docelowo pozwoli edytować teksty landingu bez programisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Subskrypcja&lt;/td&gt;&lt;td&gt;Cykliczna opłata za korzystanie z serwisu („od X zł/mies.&quot; po darmowym okresie).&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1660" width="1020" height="400" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
