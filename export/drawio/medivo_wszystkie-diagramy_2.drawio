            <mxPoint x="1330" y="1425" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="el2" value="[else] pacjent porzuca checkout bez dokończenia" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="118" y="1429" width="340" height="16" as="geometry" />
