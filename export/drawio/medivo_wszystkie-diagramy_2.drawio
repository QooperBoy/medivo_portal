            <mxPoint x="1010" y="1650" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m18" value="18: zwalnia blokadę — termin do puli (A3/A4)" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
