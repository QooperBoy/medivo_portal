        <mxCell id="m15" value="15: serwer odwołuje timer blokady —&lt;br&gt;nie jest już potrzebny" style="html=1;fontSize=11;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;rounded=0;" edge="1" parent="1">
