        <mxCell id="ed4" value="komunikat&lt;br&gt;o sankcji" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nG7" target="nB6">
