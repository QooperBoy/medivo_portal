          <mxGeometry x="60" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF2" value="&lt;b&gt;F2&lt;/b&gt;&lt;br&gt;moderacja opinii" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF3" value="&lt;b&gt;F3&lt;/b&gt;&lt;br&gt;spory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="100" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nF4" value="&lt;b&gt;F4&lt;/b&gt;&lt;br&gt;anty-abuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf2e8;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="100" width="200" height="60" as="geometry" />
