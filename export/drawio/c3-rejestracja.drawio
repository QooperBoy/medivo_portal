        <mxCell id="panelOpis" value="&lt;b&gt;Co opisuje ten diagram&lt;/b&gt;&lt;br&gt;&lt;br&gt;Diagram pokazuje rejestrację specjalisty w serwisie. Specjalista wypełnia formularz (e-mail, telefon, numer PWZ), a system sprawdza poprawność formatu numeru PWZ i potwierdza numer telefonu jednorazowym kodem SMS (OTP). Po poprawnym wpisaniu kodu powstaje konto specjalisty i automatycznie rusza weryfikacja uprawnień w rejestrze (D1), a specjalista trafia do panelu w stanie „w trakcie&quot; (D2). Flow kończy się utworzonym kontem i widocznym statusem weryfikacji." style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1030" width="1020" height="150" as="geometry" />
        </mxCell>
        <mxCell id="panelPowiazane" value="&lt;b&gt;Powiązane diagramy&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;ID&lt;/th&gt;&lt;th&gt;Plik&lt;/th&gt;&lt;th&gt;Jak się łączy&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c1-landing-dla-specjalistow.md&lt;/td&gt;&lt;td&gt;wejście do formularza rejestracji z landingu&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;C2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/c2-cennik-b2b.md&lt;/td&gt;&lt;td&gt;wejście do formularza rejestracji z cennika B2B&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D1&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d1-weryfikacja-pwz.md&lt;/td&gt;&lt;td&gt;po utworzeniu konta automatycznie startuje weryfikacja PWZ&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;D2&lt;/td&gt;&lt;td&gt;diagrams/cd-specjalista-onboarding/d2-stan-w-trakcie.md&lt;/td&gt;&lt;td&gt;po rejestracji specjalista ląduje w panelu w stanie „w trakcie&quot;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;F1&lt;/td&gt;&lt;td&gt;diagrams/f-backoffice/f1-kolejka-weryfikacji-pwz.md&lt;/td&gt;&lt;td&gt;merytoryczną weryfikację przy niepewności automatu przejmuje ręczna kolejka admina&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;B1&lt;/td&gt;&lt;td&gt;diagrams/b-pacjent-konto/b1-logowanie.md&lt;/td&gt;&lt;td&gt;limit prób OTP przyjęty przez analogię do logowania pacjenta&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;CORE-WERYFIKACJA&lt;/td&gt;&lt;td&gt;diagrams/00-core/00-weryfikacja-specjalisty.md&lt;/td&gt;&lt;td&gt;nowe konto wchodzi w stany cyklu weryfikacji (zarejestrowany → weryfikacja_auto)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1210" width="1020" height="350" as="geometry" />
        </mxCell>
        <mxCell id="panelSlownik" value="&lt;b&gt;Słownik&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;1&quot; cellpadding=&quot;4&quot; style=&quot;border-collapse:collapse;width:100%&quot;&gt;&lt;tr&gt;&lt;th&gt;Pojęcie&lt;/th&gt;&lt;th&gt;Wyjaśnienie&lt;/th&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;PWZ&lt;/td&gt;&lt;td&gt;Numer prawa wykonywania zawodu, potwierdzający uprawnienia specjalisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;OTP&lt;/td&gt;&lt;td&gt;Jednorazowy kod wysyłany SMS-em, którym specjalista potwierdza swój numer telefonu.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Walidacja formatu PWZ&lt;/td&gt;&lt;td&gt;Sprawdzenie, czy wpisany numer „wygląda poprawnie&quot; (długość, znaki) — bez sprawdzania w rejestrze.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Weryfikacja w rejestrze&lt;/td&gt;&lt;td&gt;Właściwe, merytoryczne sprawdzenie numeru PWZ w oficjalnym rejestrze — robi to dopiero flow D1.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;KRL/KIF&lt;/td&gt;&lt;td&gt;Oficjalne rejestry zawodowe, w których automat sprawdza numer PWZ specjalisty.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Limit prób (rate limiting)&lt;/td&gt;&lt;td&gt;Ograniczenie liczby ponownych wysyłek i wpisań kodu OTP, chroniące przed nadużyciami.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Stan weryfikacji&lt;/td&gt;&lt;td&gt;Etap, na którym znajduje się konto specjalisty (np. zarejestrowany, weryfikacja_auto), wg cyklu CORE-WERYFIKACJA.&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Fallback&lt;/td&gt;&lt;td&gt;Ścieżka awaryjna — gdy automat nie potwierdzi PWZ, sprawę przejmuje człowiek (kolejka F1).&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="40" y="1590" width="1020" height="380" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
