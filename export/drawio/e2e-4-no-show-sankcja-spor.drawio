        </mxCell>
        <mxCell id="ed4" value="komunikat&lt;br&gt;o sankcji" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nG7" target="nB6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed5" value="ticket" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nB6" target="nF3">
          <mxGeometry relative="1" as="geometry" />
