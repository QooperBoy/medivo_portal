          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed2" value="event&lt;br&gt;visit.no_show" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="nE7" target="nG7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ed3" value="przy 2. no-show" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;dashed=1;labelBackgroundColor=#ffffff;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="nG7" target="nGATE">
