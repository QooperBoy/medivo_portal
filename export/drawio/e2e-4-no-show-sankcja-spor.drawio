        <mxCell id="nGATE" value="&lt;b&gt;A5&lt;/b&gt;&lt;br&gt;gate przedpłaty" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4fd;strokeColor=#2d7dd2;fontSize=12;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="445" y="230" width="180" height="60" as="geometry" />
